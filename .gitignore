```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
vendor/
composer.lock
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
coverage/
htmlcov/
*.log
*.tmp
*.swp
*.swo

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Cache directories
.cache/
.mypy_cache/
.pytest_cache/
.gradle/
```